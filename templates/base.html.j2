<!doctype html>
<html lang="{{ site.language }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }}</title>
    <meta name="description" content="{{ site.description }}">
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }} RSS" href="{{ route('rss.xml') }}">
    <link rel="stylesheet" href="{{ route('assets/styles.css') }}">
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="{{ route() }}">{{ site.title }}</a>
      <nav aria-label="主导航">
        <a href="{{ route('archive/') }}">归档</a>
        <a href="{{ route('sources/') }}">新闻源</a>
        <a href="{{ route('about/') }}">关于</a>
        <a href="{{ site.repository_url }}">GitHub</a>
      </nav>
    </header>
    <main>
      {% block content %}{% endblock %}
    </main>
    <footer>
      <p>只提供摘要与原文链接。<a href="{{ site.issues_url }}">反馈问题</a></p>
    </footer>
  </body>
</html>
