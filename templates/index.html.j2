{% extends "base.html.j2" %}
{% block content %}
  <h1>{{ site.title }}</h1>
  <p>{{ site.description }}</p>
  {% if latest %}
    <section>
      <h2>最新一期</h2>
      <p><a href="{{ latest.url }}">{{ latest.date }}</a> · {{ latest.article_count }} 条新闻</p>
    </section>
    <section>
      <h2>最近更新</h2>
      <ul class="issue-list">
        {% for issue in recent %}
          <li>
            <a href="{{ issue.url }}">{{ issue.date }}</a>
            · {{ issue.article_count }} 条 · {{ issue.source_count }} 个来源
          </li>
        {% endfor %}
      </ul>
    </section>
  {% else %}
    <p>首期日刊正在准备中。</p>
  {% endif %}
{% endblock %}
